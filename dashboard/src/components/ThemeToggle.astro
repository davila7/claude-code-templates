---
---

<button
  type="button"
  class="theme-toggle-btn relative flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-border bg-glass text-text-tertiary hover:bg-glass-hover hover:text-text-primary transition-colors"
  aria-label="Toggle light or dark theme"
  title="Theme"
>
  <svg
    class="theme-icon-sun absolute h-3.5 w-3.5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="1.75"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    />
  </svg>
  <svg
    class="theme-icon-moon absolute h-3.5 w-3.5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="1.75"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
  </svg>
</button>

<style is:global>
  html.theme-dark .theme-toggle-btn .theme-icon-sun {
    opacity: 1;
  }
  html.theme-dark .theme-toggle-btn .theme-icon-moon {
    opacity: 0;
    pointer-events: none;
  }
  html.theme-light .theme-toggle-btn .theme-icon-sun {
    opacity: 0;
    pointer-events: none;
  }
  html.theme-light .theme-toggle-btn .theme-icon-moon {
    opacity: 1;
  }
</style>
