---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import TopBar from '../components/TopBar.astro';
import SearchModal from '../components/SearchModal.tsx';
import CartSidebar from '../components/CartSidebar.tsx';

export const prerender = true;

const title = 'Autonomous Teams — AI Agent Teams for Complex Tasks';
const description = 'Browse autonomous AI agent teams. Pre-built teams of specialized agents that work together to accomplish complex tasks like code review, testing, deployment, and more.';

// Autonomous teams data
interface Team {
  slug: string;
  name: string;
  description: string;
  agents: number;
  category: string;
  tags: string[];
  gradient: string;
  borderGradient: string;
}

const teams: Team[] = [
  // Coming soon: Pre-built autonomous teams
];
---

<DashboardLayout title={title} description={description}>
  <TopBar />
  
  <!-- Hero Section -->
  <div class="relative overflow-hidden border-b border-[var(--color-border)]">
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-surface-0)] via-[var(--color-surface-1)] to-[var(--color-surface-0)]"></div>
    
    <div class="relative px-6 py-20 max-w-7xl mx-auto">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-surface-2)] border border-[var(--color-border)] text-xs font-medium text-[var(--color-text-secondary)] mb-6">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Autonomous AI Teams
        </div>
        
        <h1 class="text-5xl md:text-6xl font-semibold text-[var(--color-text-primary)] mb-6 tracking-tight leading-[1.1]">
          Teams that think<br/>and work together
        </h1>
        
        <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed">
          Pre-built teams of specialized AI agents that collaborate autonomously to accomplish complex tasks with precision and depth.
        </p>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="px-6 py-16 max-w-7xl mx-auto">
    
    <!-- What Are Autonomous Teams -->
    <section class="mb-20">
      <h2 class="text-3xl font-semibold text-[var(--color-text-primary)] mb-12">Built for collaboration</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="group">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-500/10 to-blue-600/10 border border-blue-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">Collaborative</h3>
          <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">Agents work together, sharing insights and building on each other's findings to provide comprehensive analysis.</p>
        </div>
        
        <div class="group">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-purple-500/10 to-purple-600/10 border border-purple-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">Specialized</h3>
          <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">Each agent is an expert in their domain with deep knowledge, specific rules, and focused responsibilities.</p>
        </div>
        
        <div class="group">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-green-500/10 to-green-600/10 border border-green-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">Autonomous</h3>
          <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">Teams self-organize and coordinate through an orchestrator, requiring minimal human intervention.</p>
        </div>
      </div>
    </section>

    <!-- Teams Grid -->
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-3xl font-semibold text-[var(--color-text-primary)]">Available teams</h2>
      </div>
      
      {teams.length === 0 ? (
        <div class="relative overflow-hidden p-16 rounded-3xl bg-gradient-to-br from-blue-500/5 to-purple-500/5 border border-[var(--color-border)] text-center">
          <div class="relative z-10 max-w-2xl mx-auto">
            <div class="w-20 h-20 rounded-3xl bg-gradient-to-br from-blue-500/10 to-purple-600/10 border border-blue-500/20 flex items-center justify-center mb-6 mx-auto">
              <svg class="w-10 h-10 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-3xl font-semibold text-[var(--color-text-primary)] mb-4">Coming Soon</h3>
            <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed mb-8">
              Pre-built autonomous agent teams are currently in development. In the meantime, you can create your own custom teams using the template below.
            </p>
            <a 
              href="#create-your-own"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[var(--color-primary-500)] text-white font-medium hover:bg-[var(--color-primary-600)] transition-colors"
            >
              <span>Create Your Own Team</span>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
          </div>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 gap-6">
          {teams.map(team => (
            <a 
              href={`/autonomous-teams/${team.slug}`}
              class="group relative overflow-hidden p-8 rounded-3xl bg-gradient-to-br {team.gradient} border border-[var(--color-border)] hover:border-[var(--color-primary-500)]/30 transition-all duration-500 hover:shadow-2xl hover:shadow-[var(--color-primary-500)]/5"
            >
              <div class="relative z-10">
                <div class="flex items-start justify-between mb-6">
                  <div class="flex-1">
                    <h3 class="text-2xl font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-primary-500)] transition-colors">
                      {team.name}
                    </h3>
                    <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">{team.description}</p>
                  </div>
                  <svg class="w-6 h-6 text-[var(--color-text-tertiary)] group-hover:text-[var(--color-primary-500)] group-hover:translate-x-1 transition-all shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
                
                <div class="flex items-center gap-6 text-sm mb-4">
                  <div class="flex items-center gap-2 text-[var(--color-text-secondary)]">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                    <span class="font-medium">{team.agents}</span>
                    <span>agents</span>
                  </div>
                  <span class="px-3 py-1 rounded-full bg-[var(--color-surface-2)] border border-[var(--color-border)] text-xs font-medium">{team.category}</span>
                </div>
                
                <div class="flex flex-wrap gap-2">
                  {team.tags.map(tag => (
                    <span class="px-2.5 py-1 rounded-lg bg-[var(--color-surface-2)]/50 border border-[var(--color-border)]/50 text-xs text-[var(--color-text-secondary)]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              
              <!-- Subtle gradient overlay on hover -->
              <div class="absolute inset-0 bg-gradient-to-br {team.borderGradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- Create Your Own Team Section -->
    <section id="create-your-own" class="mt-20 scroll-mt-20">
      <div class="relative overflow-hidden p-12 rounded-3xl bg-gradient-to-br from-green-500/5 to-emerald-500/5 border border-[var(--color-border)]">
        <div class="relative z-10 max-w-4xl">
          <div class="flex items-start gap-6 mb-8">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-green-500/10 to-emerald-600/10 border border-green-500/20 flex items-center justify-center shrink-0">
              <svg class="w-8 h-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="text-3xl font-semibold text-[var(--color-text-primary)] mb-3">Create your own team</h2>
              <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed mb-6">
                Use our comprehensive template to build custom autonomous agent teams tailored to your specific needs. Includes orchestrator patterns, agent templates, and complete documentation.
              </p>
              <div class="flex flex-wrap gap-4">
                <a 
                  href="/autonomous-teams/autonomous-team-template"
                  class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[var(--color-primary-500)] text-white font-medium hover:bg-[var(--color-primary-600)] transition-colors"
                >
                  <span>View Template</span>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
                <a 
                  href="https://github.com/cline/claude-code-templates"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[var(--color-surface-2)] text-[var(--color-text-primary)] font-medium border border-[var(--color-border)] hover:border-[var(--color-primary-500)]/30 transition-colors"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                  </svg>
                  <span>View on GitHub</span>
                </a>
              </div>
            </div>
          </div>
          
          <div class="grid md:grid-cols-3 gap-6">
            <div class="p-6 rounded-2xl bg-[var(--color-surface-1)]/50 border border-[var(--color-border)]/50">
              <div class="text-3xl font-bold text-[var(--color-primary-500)] mb-2">Complete</div>
              <p class="text-sm text-[var(--color-text-secondary)]">Full template structure with orchestrator, agents, rules, and documentation</p>
            </div>
            <div class="p-6 rounded-2xl bg-[var(--color-surface-1)]/50 border border-[var(--color-border)]/50">
              <div class="text-3xl font-bold text-[var(--color-primary-500)] mb-2">Flexible</div>
              <p class="text-sm text-[var(--color-text-secondary)]">Customize every aspect to match your team's specific requirements</p>
            </div>
            <div class="p-6 rounded-2xl bg-[var(--color-surface-1)]/50 border border-[var(--color-border)]/50">
              <div class="text-3xl font-bold text-[var(--color-primary-500)] mb-2">Documented</div>
              <p class="text-sm text-[var(--color-text-secondary)]">Step-by-step guides and examples to get you started quickly</p>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>

  <SearchModal client:idle />
  <CartSidebar client:idle />
</DashboardLayout>
