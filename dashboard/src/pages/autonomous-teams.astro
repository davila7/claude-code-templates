---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import TopBar from '../components/TopBar.astro';
import SearchModal from '../components/SearchModal.tsx';
import CartSidebar from '../components/CartSidebar.tsx';

export const prerender = true;

const title = 'Autonomous Teams — AI Agent Teams for Complex Tasks';
const description = 'Browse autonomous AI agent teams. Pre-built teams of specialized agents that work together to accomplish complex tasks like code review, testing, deployment, and more.';

// Autonomous teams data
interface Team {
  slug: string;
  name: string;
  description: string;
  agents: number;
  category: string;
  tags: string[];
  gradient: string;
  borderGradient: string;
}

const teams: Team[] = [
  // Coming soon: Pre-built autonomous teams
];
---

<DashboardLayout title={title} description={description}>
  <TopBar />
  
  <!-- Hero Section -->
  <div class="relative overflow-hidden border-b border-[var(--color-border)]">
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-surface-0)] via-[var(--color-surface-1)] to-[var(--color-surface-0)]"></div>
    
    <!-- Animated background elements -->
    <div class="absolute inset-0 overflow-hidden opacity-30">
      <div class="absolute top-20 left-10 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    </div>
    
    <div class="relative px-6 py-24 max-w-7xl mx-auto">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-blue-500/10 to-purple-500/10 border border-blue-500/20 text-sm font-medium text-[var(--color-text-primary)] mb-8 backdrop-blur-sm">
          <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Autonomous AI Teams
        </div>
        
        <h1 class="text-6xl md:text-7xl font-bold text-[var(--color-text-primary)] mb-8 tracking-tight leading-[1.05]">
          Teams that think<br/>and work together
        </h1>
        
        <p class="text-2xl text-[var(--color-text-secondary)] leading-relaxed mb-12 max-w-3xl mx-auto">
          Pre-built teams of specialized AI agents that collaborate autonomously to accomplish complex tasks with precision and depth.
        </p>
        
        <!-- Quick action buttons -->
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a 
            href="#create-your-own"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-[var(--color-primary-500)] text-white text-lg font-semibold hover:bg-[var(--color-primary-600)] transition-all duration-300 hover:scale-105 shadow-lg shadow-[var(--color-primary-500)]/25"
          >
            <span>Create Your Team</span>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a 
            href="/build-team"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-[var(--color-surface-2)] text-[var(--color-text-primary)] text-lg font-semibold border border-[var(--color-border)] hover:border-[var(--color-primary-500)]/30 transition-all duration-300 hover:scale-105 backdrop-blur-sm"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            <span>Interactive Guide</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="px-6 py-16 max-w-7xl mx-auto">
    
    <!-- What Are Autonomous Teams -->
    <section class="mb-24">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-[var(--color-text-primary)] mb-4">Built for collaboration</h2>
        <p class="text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto">
          Autonomous teams combine specialized expertise with seamless coordination
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="group relative overflow-hidden p-8 rounded-3xl bg-gradient-to-br from-blue-500/5 to-blue-600/5 border border-blue-500/20 hover:border-blue-500/40 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-500/10 hover:-translate-y-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/5 rounded-full blur-2xl group-hover:bg-blue-500/10 transition-colors duration-500"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500/20 to-blue-600/20 border border-blue-500/30 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
              <svg class="w-7 h-7 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[var(--color-text-primary)] mb-3">Collaborative</h3>
            <p class="text-base text-[var(--color-text-secondary)] leading-relaxed">Agents work together, sharing insights and building on each other's findings to provide comprehensive analysis.</p>
          </div>
        </div>
        
        <div class="group relative overflow-hidden p-8 rounded-3xl bg-gradient-to-br from-purple-500/5 to-purple-600/5 border border-purple-500/20 hover:border-purple-500/40 transition-all duration-500 hover:shadow-2xl hover:shadow-purple-500/10 hover:-translate-y-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-purple-500/5 rounded-full blur-2xl group-hover:bg-purple-500/10 transition-colors duration-500"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-500/20 to-purple-600/20 border border-purple-500/30 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
              <svg class="w-7 h-7 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[var(--color-text-primary)] mb-3">Specialized</h3>
            <p class="text-base text-[var(--color-text-secondary)] leading-relaxed">Each agent is an expert in their domain with deep knowledge, specific rules, and focused responsibilities.</p>
          </div>
        </div>
        
        <div class="group relative overflow-hidden p-8 rounded-3xl bg-gradient-to-br from-green-500/5 to-green-600/5 border border-green-500/20 hover:border-green-500/40 transition-all duration-500 hover:shadow-2xl hover:shadow-green-500/10 hover:-translate-y-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-green-500/5 rounded-full blur-2xl group-hover:bg-green-500/10 transition-colors duration-500"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-green-500/20 to-green-600/20 border border-green-500/30 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
              <svg class="w-7 h-7 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[var(--color-text-primary)] mb-3">Autonomous</h3>
            <p class="text-base text-[var(--color-text-secondary)] leading-relaxed">Teams self-organize and coordinate through an orchestrator, requiring minimal human intervention.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Teams Grid -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-[var(--color-text-primary)] mb-4">Pre-built teams</h2>
        <p class="text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto">
          Ready-to-use autonomous teams for common workflows
        </p>
      </div>
      
      {teams.length === 0 ? (
        <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-blue-500/5 via-purple-500/5 to-pink-500/5 border border-[var(--color-border)]">
          <!-- Animated gradient background -->
          <div class="absolute inset-0 opacity-50">
            <div class="absolute top-0 left-0 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl animate-pulse"></div>
            <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1.5s;"></div>
          </div>
          
          <div class="relative z-10 p-16 text-center">
            <div class="max-w-3xl mx-auto">
              <!-- Icon with animation -->
              <div class="relative w-24 h-24 mx-auto mb-8">
                <div class="absolute inset-0 bg-gradient-to-br from-blue-500/20 to-purple-600/20 rounded-3xl animate-pulse"></div>
                <div class="relative w-24 h-24 rounded-3xl bg-gradient-to-br from-blue-500/10 to-purple-600/10 border border-blue-500/30 flex items-center justify-center backdrop-blur-sm">
                  <svg class="w-12 h-12 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                  </svg>
                </div>
              </div>
              
              <!-- Status badge -->
              <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/30 text-sm font-semibold text-amber-600 dark:text-amber-400 mb-6">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                In Development
              </div>
              
              <h3 class="text-4xl font-bold text-[var(--color-text-primary)] mb-6">Pre-built teams coming soon</h3>
              <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed mb-10">
                We're crafting specialized autonomous teams for code review, testing, deployment, and more. While we perfect these, you can create your own custom teams using our comprehensive template.
              </p>
              
              <!-- Action buttons -->
              <div class="flex flex-wrap items-center justify-center gap-4 mb-12">
                <a 
                  href="#create-your-own"
                  class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-[var(--color-primary-500)] text-white text-lg font-semibold hover:bg-[var(--color-primary-600)] transition-all duration-300 hover:scale-105 shadow-lg shadow-[var(--color-primary-500)]/25"
                >
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                  <span>Create Your Own Team</span>
                </a>
                <a 
                  href="/build-team"
                  class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-[var(--color-surface-2)] text-[var(--color-text-primary)] text-lg font-semibold border border-[var(--color-border)] hover:border-[var(--color-primary-500)]/30 transition-all duration-300 hover:scale-105 backdrop-blur-sm"
                >
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                  <span>View Interactive Guide</span>
                </a>
              </div>
              
              <!-- Feature highlights -->
              <div class="grid md:grid-cols-3 gap-6 text-left">
                <div class="p-6 rounded-2xl bg-[var(--color-surface-1)]/50 border border-[var(--color-border)]/50 backdrop-blur-sm">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500/20 to-blue-600/20 border border-blue-500/30 flex items-center justify-center">
                      <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                    </div>
                    <h4 class="text-lg font-bold text-[var(--color-text-primary)]">Complete Template</h4>
                  </div>
                  <p class="text-sm text-[var(--color-text-secondary)]">Full structure with orchestrator, agents, rules, and documentation ready to customize</p>
                </div>
                
                <div class="p-6 rounded-2xl bg-[var(--color-surface-1)]/50 border border-[var(--color-border)]/50 backdrop-blur-sm">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500/20 to-purple-600/20 border border-purple-500/30 flex items-center justify-center">
                      <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                      </svg>
                    </div>
                    <h4 class="text-lg font-bold text-[var(--color-text-primary)]">Fully Customizable</h4>
                  </div>
                  <p class="text-sm text-[var(--color-text-secondary)]">Adapt every aspect to match your specific workflow and requirements</p>
                </div>
                
                <div class="p-6 rounded-2xl bg-[var(--color-surface-1)]/50 border border-[var(--color-border)]/50 backdrop-blur-sm">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500/20 to-green-600/20 border border-green-500/30 flex items-center justify-center">
                      <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                    </div>
                    <h4 class="text-lg font-bold text-[var(--color-text-primary)]">Well Documented</h4>
                  </div>
                  <p class="text-sm text-[var(--color-text-secondary)]">Step-by-step guides and examples to get you started quickly</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 gap-6">
          {teams.map(team => (
            <a 
              href={`/autonomous-teams/${team.slug}`}
              class="group relative overflow-hidden p-8 rounded-3xl bg-gradient-to-br {team.gradient} border border-[var(--color-border)] hover:border-[var(--color-primary-500)]/30 transition-all duration-500 hover:shadow-2xl hover:shadow-[var(--color-primary-500)]/5"
            >
              <div class="relative z-10">
                <div class="flex items-start justify-between mb-6">
                  <div class="flex-1">
                    <h3 class="text-2xl font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-primary-500)] transition-colors">
                      {team.name}
                    </h3>
                    <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">{team.description}</p>
                  </div>
                  <svg class="w-6 h-6 text-[var(--color-text-tertiary)] group-hover:text-[var(--color-primary-500)] group-hover:translate-x-1 transition-all shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
                
                <div class="flex items-center gap-6 text-sm mb-4">
                  <div class="flex items-center gap-2 text-[var(--color-text-secondary)]">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                    <span class="font-medium">{team.agents}</span>
                    <span>agents</span>
                  </div>
                  <span class="px-3 py-1 rounded-full bg-[var(--color-surface-2)] border border-[var(--color-border)] text-xs font-medium">{team.category}</span>
                </div>
                
                <div class="flex flex-wrap gap-2">
                  {team.tags.map(tag => (
                    <span class="px-2.5 py-1 rounded-lg bg-[var(--color-surface-2)]/50 border border-[var(--color-border)]/50 text-xs text-[var(--color-text-secondary)]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              
              <!-- Subtle gradient overlay on hover -->
              <div class="absolute inset-0 bg-gradient-to-br {team.borderGradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- Create Your Own Team Section -->
    <section id="create-your-own" class="scroll-mt-20">
      <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-green-500/5 via-emerald-500/5 to-teal-500/5 border border-green-500/20">
        <!-- Animated background -->
        <div class="absolute inset-0 opacity-30">
          <div class="absolute top-10 right-10 w-72 h-72 bg-green-500/10 rounded-full blur-3xl animate-pulse"></div>
          <div class="absolute bottom-10 left-10 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
        </div>
        
        <div class="relative z-10 p-12">
          <div class="max-w-5xl mx-auto">
            <!-- Header -->
            <div class="flex flex-col md:flex-row items-start gap-8 mb-12">
              <div class="shrink-0">
                <div class="w-20 h-20 rounded-3xl bg-gradient-to-br from-green-500/20 to-emerald-600/20 border border-green-500/30 flex items-center justify-center backdrop-blur-sm">
                  <svg class="w-10 h-10 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                </div>
              </div>
              
              <div class="flex-1">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-500/10 border border-green-500/20 text-sm font-semibold text-green-600 dark:text-green-400 mb-4">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  Available Now
                </div>
                
                <h2 class="text-4xl md:text-5xl font-bold text-[var(--color-text-primary)] mb-4">Create your own team</h2>
                <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed mb-8">
                  Use our comprehensive template to build custom autonomous agent teams tailored to your specific needs. Includes orchestrator patterns, agent templates, and complete documentation.
                </p>
                
                <!-- Action buttons -->
                <div class="flex flex-wrap gap-4 mb-8">
                  <a 
                    href="/autonomous-teams/autonomous-team-template"
                    class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-[var(--color-primary-500)] text-white text-lg font-semibold hover:bg-[var(--color-primary-600)] transition-all duration-300 hover:scale-105 shadow-lg shadow-[var(--color-primary-500)]/25"
                  >
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    <span>View Template</span>
                  </a>
                  <a 
                    href="/build-team"
