---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import TopBar from '../../components/TopBar.astro';

const title = 'Submit Showcase | Claude Code Templates';
const description = 'Share your workflow or success story with the community';
---

<DashboardLayout title={title} description={description}>
  <TopBar />
  
  <div class="max-w-3xl mx-auto px-6 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-[20px] font-semibold text-[#ededed] mb-2">Submit Showcase</h1>
      <p class="text-[13px] text-[#999]">Share your workflow, success story, or best practices with the community</p>
    </div>

    <!-- Form -->
    <form id="submitForm" class="space-y-6">
      <!-- Title -->
      <div>
        <label for="title" class="block text-[12px] font-medium text-[#ededed] mb-2">
          Title <span class="text-red-400">*</span>
        </label>
        <input
          type="text"
          id="title"
          name="title"
          required
          maxlength="200"
          placeholder="e.g., Automated Testing Workflow with Vitest"
          class="w-full bg-[#0a0a0a] border border-[#1f1f1f] rounded-lg text-[13px] text-[#ededed] placeholder:text-[#666] px-3 py-2 outline-none focus:bg-[#111] focus:ring-1 focus:ring-[#2a2a2a] transition-all"
        />
      </div>

      <!-- Description -->
      <div>
        <label for="description" class="block text-[12px] font-medium text-[#ededed] mb-2">
          Description <span class="text-red-400">*</span>
        </label>
        <textarea
          id="description"
          name="description"
          required
          maxlength="500"
          rows="3"
          placeholder="Brief description of your showcase..."
          class="w-full bg-[#0a0a0a] border border-[#1f1f1f] rounded-lg text-[13px] text-[#ededed] placeholder:text-[#666] px-3 py-2 outline-none focus:bg-[#111] focus:ring-1 focus:ring-[#2a2a2a] transition-all resize-none"
        ></textarea>
      </div>

      <!-- Type -->
      <div>
        <label for="type" class="block text-[12px] font-medium text-[#ededed] mb-2">
          Type <span class="text-red-400">*</span>
        </label>
        <select
          id="type"
          name="type"
          required
          class="w-full bg-[#0a0a0a] border border-[#1f1f1f] rounded-lg text-[13px] text-[#ededed] px-3 py-2 outline-none focus:bg-[#111] cursor-pointer"
        >
          <option value="">Select type...</option>
          <option value="workflow">Workflow</option>
          <option value="success_story">Success Story</option>
          <option value="before_after">Before/After</option>
          <option value="configuration">Configuration</option>
        </select>
      </div>

      <!-- Category -->
      <div>
        <label for="category" class="block text-[12px] font-medium text-[#ededed] mb-2">
          Category <span class="text-red-400">*</span>
        </label>
        <select
          id="category"
          name="category"
          required
          class="w-full bg-[#0a0a0a] border border-[#1f1f1f] rounded-lg text-[13px] text-[#ededed] px-3 py-2 outline-none focus:bg-[#111] cursor-pointer"
        >
          <option value="">Select category...</option>
          <option value="automation">Automation</option>
          <option value="testing">Testing</option>
          <option value="deployment">Deployment</option>
          <option value="ai-agents">AI Agents</option>
          <option value="performance">Performance</option>
          <option value="security">Security</option>
          <option value="best-practices">Best Practices</option>
        </select>
      </div>

      <!-- Content -->
      <div>
        <label for="content" class="block text-[12px] font-medium text-[#ededed] mb-2">
          Content <span class="text-red-400">*</span>
          <span class="text-[11px] text-[#666] font-normal ml-2">(Markdown supported)</span>
        </label>
        <textarea
          id="content"
          name="content"
          required
          rows="12"
          placeholder="Share your story, workflow, or best practices in detail..."
          class="w-full bg-[#0a0a0a] border border-[#1f1f1f] rounded-lg text-[13px] text-[#ededed] placeholder:text-[#666] px-3 py-2 outline-none focus:bg-[#111] focus:ring-1 focus:ring-[#2a2a2a] transition-all resize-none font-mono"
        ></textarea>
      </div>

      <!-- Code Before/After (optional) -->
      <div id="codeSection" class="hidden space-y-4">
        <div>
          <label for="codeBefore" class="block text-[12px] font-medium text-[#ededed] mb-2">
            Code Before (optional)
          </label>
          <textarea
            id="codeBefore"
            name="codeBefore"
            rows="6"
            placeholder="Paste your code before improvements..."
            class="w-full bg-[#0a0a0a] border border-[#1f1f1f] rounded-lg text-[12px] text-[#ededed] placeholder:text-[#666] px-3 py-2 outline-none focus:bg-[#111] focus:ring-1 focus:ring-[#2a2a2a] transition-all resize-none font-mono"
          ></textarea>
        </div>
        <div>
          <label for="codeAfter" class="block text-[12px] font-medium text-[#ededed] mb-2">
            Code After (optional)
          </label>
          <textarea
            id="codeAfter"
            name="codeAfter"
            rows="6"
            placeholder="Paste your improved code..."
            class="w-full bg-[#0a0a0a] border border-[#1f1f1f] rounded-lg text-[12px] text-[#ededed] placeholder:text-[#666] px-3 py-2 outline-none focus:bg-[#111] focus:ring-1 focus:ring-[#2a2a2a] transition-all resize-none font-mono"
          ></textarea>
        </div>
      </div>

      <!-- Tags -->
      <div>
        <label for="tags" class="block text-[12px] font-medium text-[#ededed] mb-2">
          Tags (optional)
          <span class="text-[11px] text-[#666] font-normal ml-2">(comma-separated)</span>
        </label>
        <input
          type="text"
          id="tags"
          name="tags"
          placeholder="e.g., testing, automation, vitest"
          class="w-full bg-[#0a0a0a] border border-[#1f1f1f] rounded-lg text-[13px] text-[#ededed] placeholder:text-[#666] px-3 py-2 outline-none focus:bg-[#111] focus:ring-1 focus:ring-[#2a2a2a] transition-all"
        />
      </div>

      <!-- Submit -->
      <div class="flex items-center gap-3 pt-4">
        <button
          type="submit"
          id="submitBtn"
          class="px-6 py-2.5 bg-[#3b82f6] hover:bg-[#2563eb] text-white rounded-lg text-[13px] font-medium transition-all disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Submit Showcase
        </button>
        <a
          href="/showcase"
          class="px-6 py-2.5 bg-[#0a0a0a] hover:bg-[#111] border border-[#1f1f1f] text-[#999] rounded-lg text-[13px] font-medium transition-all"
        >
          Cancel
        </a>
      </div>

      <!-- Success Message -->
      <div id="successMessage" class="hidden p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-lg">
        <p class="text-[13px] text-emerald-400">✓ Showcase submitted successfully! Redirecting...</p>
      </div>

      <!-- Error Message -->
      <div id="errorMessage" class="hidden p-4 bg-red-500/10 border border-red-500/20 rounded-lg">
        <p class="text-[13px] text-red-400"></p>
      </div>
    </form>
  </div>
</DashboardLayout>

<script>
  // Show/hide code section based on type
  const typeSelect = document.getElementById('type') as HTMLSelectElement;
  const codeSection = document.getElementById('codeSection');

  typeSelect?.addEventListener('change', () => {
    if (typeSelect.value === 'before_after') {
      codeSection?.classList.remove('hidden');
    } else {
      codeSection?.classList.add('hidden');
    }
  });

  // Form submission
  const form = document.getElementById('submitForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const successMessage = document.getElementById('successMessage');
  const errorMessage = document.getElementById('errorMessage');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    
    const formData = new FormData(form);
    const tags = (formData.get('tags') as string)?.split(',').map(t => t.trim()).filter(Boolean) || [];
    
    const data = {
      title: formData.get('title'),
      description: formData.get('description'),
      content: formData.get('content'),
      submissionType: formData.get('type'),
      category: formData.get('category'),
      codeBefore: formData.get('codeBefore') || null,
      codeAfter: formData.get('codeAfter') || null,
      tags,
    };

    try {
      const response = await fetch('/api/showcase/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        successMessage?.classList.remove('hidden');
        errorMessage?.classList.add('hidden');
        form.reset();
        
        setTimeout(() => {
          window.location.href = '/showcase';
        }, 2000);
      } else {
        const error = await response.json();
        throw new Error(error.error || 'Failed to submit showcase');
      }
    } catch (error: any) {
      errorMessage?.classList.remove('hidden');
      const errorText = errorMessage?.querySelector('p');
      if (errorText) {
        errorText.textContent = error.message || 'Failed to submit showcase';
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Showcase';
    }
  });
</script>
