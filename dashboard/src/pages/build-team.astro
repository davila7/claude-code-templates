---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import TopBar from '../components/TopBar.astro';
import SearchModal from '../components/SearchModal.tsx';
import CartSidebar from '../components/CartSidebar.tsx';

export const prerender = true;

const title = 'Build Your Team — Create Autonomous AI Agent Teams';
const description = 'Interactive guide to building your own autonomous AI agent teams. Step-by-step instructions, patterns, and examples.';

const steps = [
  {
    number: 1,
    title: 'Choose Your Domain',
    description: 'Select what your team will specialize in',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />',
    color: 'blue'
  },
  {
    number: 2,
    title: 'Copy Template',
    description: 'Start with our proven structure',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />',
    color: 'purple'
  },
  {
    number: 3,
    title: 'Configure Team',
    description: 'Define agents, roles, and workflow',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />',
    color: 'green'
  },
  {
    number: 4,
    title: 'Test & Deploy',
    description: 'Validate and publish your team',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />',
    color: 'orange'
  }
];

const domains = [
  { name: 'Customer Support', agents: ['ticket-triage', 'response-writer', 'escalation-handler'], icon: '💬' },
  { name: 'Content Creation', agents: ['researcher', 'writer', 'editor', 'seo-optimizer'], icon: '✍️' },
  { name: 'DevOps', agents: ['deployment-manager', 'monitoring-agent', 'incident-responder'], icon: '🚀' },
  { name: 'Data Analysis', agents: ['data-cleaner', 'analyzer', 'visualizer', 'reporter'], icon: '📊' },
  { name: 'Marketing', agents: ['campaign-planner', 'content-creator', 'analytics-tracker'], icon: '📈' },
  { name: 'Code Review', agents: ['security-reviewer', 'performance-reviewer', 'style-reviewer'], icon: '🔍' }
];

const patterns = [
  {
    name: 'Sequential Pipeline',
    description: 'Each step depends on previous output',
    useCase: 'Content creation, data processing',
    diagram: 'Agent 1 → Agent 2 → Agent 3',
    color: 'blue'
  },
  {
    name: 'Parallel Processing',
    description: 'Tasks run independently and simultaneously',
    useCase: 'Code review, multi-source analysis',
    diagram: 'Agent 1 ⟷ Agent 2 ⟷ Agent 3',
    color: 'purple'
  },
  {
    name: 'Hybrid (Recommended)',
    description: 'Mix of parallel and sequential work',
    useCase: 'Most complex workflows',
    diagram: '(Agent 1 + Agent 2) → Orchestrator',
    color: 'green'
  }
];
---

<DashboardLayout title={title} description={description}>
  <TopBar />
  
  <!-- Hero Section -->
  <div class="relative overflow-hidden border-b border-[var(--color-border)]">
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-surface-0)] via-[var(--color-surface-1)] to-[var(--color-surface-0)]"></div>
    
    <div class="relative px-6 py-20 max-w-7xl mx-auto">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-blue-500/10 to-purple-500/10 border border-blue-500/20 text-sm font-medium text-blue-500 mb-8">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Interactive Guide
        </div>
        
        <h1 class="text-6xl md:text-7xl font-semibold text-[var(--color-text-primary)] mb-6 tracking-tight leading-[1.1]">
          Build Your<br/>Autonomous Team
        </h1>
        
        <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed mb-10">
          Create specialized AI agent teams that work together autonomously. Follow our interactive guide with patterns, examples, and best practices.
        </p>
        
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a 
            href="#get-started"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-[var(--color-primary-500)] text-white font-medium hover:bg-[var(--color-primary-600)] transition-colors shadow-lg shadow-[var(--color-primary-500)]/20"
          >
            <span>Get Started</span>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a 
            href="/autonomous-teams/autonomous-team-template"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-[var(--color-surface-2)] text-[var(--color-text-primary)] font-medium border border-[var(--color-border)] hover:border-[var(--color-primary-500)]/30 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <span>View Template</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="px-6 py-16 max-w-7xl mx-auto">
    
    <!-- 4-Step Process -->
    <section id="get-started" class="mb-24 scroll-mt-20">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-semibold text-[var(--color-text-primary)] mb-4">Four Simple Steps</h2>
        <p class="text-lg text-[var(--color-text-secondary)]">From idea to deployed autonomous team in minutes</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {steps.map((step) => (
          <div class="group relative">
            <div class={`relative p-8 rounded-3xl bg-gradient-to-br from-[var(--color-surface-1)] to-[var(--color-surface-2)] border border-[var(--color-border)] hover:border-${step.color}-500/30 transition-all duration-300 hover:shadow-2xl hover:shadow-${step.color}-500/5 h-full`}>
              <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br from-${step.color}-500/10 to-${step.color}-600/10 border border-${step.color}-500/20 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300`}>
                <svg class={`w-8 h-8 text-${step.color}-500`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={step.icon} />
              </div>
              
              <div class={`text-sm font-semibold text-${step.color}-500 mb-2`}>Step {step.number}</div>
              <h3 class="text-xl font-semibold text-[var(--color-text-primary)] mb-3">{step.title}</h3>
              <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Domain Examples -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-semibold text-[var(--color-text-primary)] mb-4">Choose Your Domain</h2>
        <p class="text-lg text-[var(--color-text-secondary)]">Popular team types to get you started</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {domains.map((domain) => (
          <div class="group p-6 rounded-2xl bg-[var(--color-surface-1)] border border-[var(--color-border)] hover:border-[var(--color-primary-500)]/30 transition-all duration-300 hover:shadow-xl cursor-pointer">
            <div class="flex items-start gap-4 mb-4">
              <div class="text-4xl">{domain.icon}</div>
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-primary-500)] transition-colors">{domain.name}</h3>
                <div class="flex flex-wrap gap-2">
                  {domain.agents.map((agent) => (
                    <span class="px-2.5 py-1 rounded-lg bg-[var(--color-surface-2)] border border-[var(--color-border)] text-xs text-[var(--color-text-secondary)]">
                      {agent}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Workflow Patterns -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-semibold text-[var(--color-text-primary)] mb-4">Workflow Patterns</h2>
        <p class="text-lg text-[var(--color-text-secondary)]">Choose the right pattern for your use case</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        {patterns.map((pattern) => (
          <div class={`relative overflow-hidden p-8 rounded-3xl bg-gradient-to-br from-${pattern.color}-500/5 to-${pattern.color}-600/5 border border-${pattern.color}-500/20 hover:border-${pattern.color}-500/40 transition-all duration-300 hover:shadow-2xl`}>
            <div class="relative z-10">
              <h3 class={`text-xl font-semibold text-[var(--color-text-primary)] mb-3`}>{pattern.name}</h3>
              <p class="text-[15px] text-[var(--color-text-secondary)] mb-4 leading-relaxed">{pattern.description}</p>
              
              <div class={`p-4 rounded-xl bg-${pattern.color}-500/10 border border-${pattern.color}-500/20 mb-4`}>
                <div class={`text-sm font-mono text-${pattern.color}-500 text-center`}>{pattern.diagram}</div>
              </div>
              
              <div class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)]">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{pattern.useCase}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Interactive Code Example -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-semibold text-[var(--color-text-primary)] mb-4">Quick Start Code</h2>
        <p class="text-lg text-[var(--color-text-secondary)]">Copy and customize this template</p>
      </div>
      
      <div class="rounded-3xl bg-[var(--color-surface-1)] border border-[var(--color-border)] overflow-hidden">
        <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--color-border)] bg-[var(--color-surface-2)]">
          <div class="flex items-center gap-3">
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
            </div>
            <span class="text-sm font-medium text-[var(--color-text-secondary)]">team.yaml</span>
          </div>
          <button
            onclick="navigator.clipboard.writeText(document.getElementById('team-yaml-code').textContent)"
            class="px-3 py-1.5 rounded-lg bg-[var(--color-surface-1)] border border-[var(--color-border)] text-xs font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-primary-500)]/30 transition-colors"
          >
            Copy
          </button>
        </div>
        <pre class="p-6 overflow-x-auto"><code id="team-yaml-code" class="text-sm text-[var(--color-text-primary)] font-mono">team:
  name: my-awesome-team
  version: 1.0.0
  description: What your team does
  
orchestrator:
  agent: team-orchestrator
  role: Coordinates workflow
  
agents:
  - id: agent-1
    role: First specialist
    priority: 1
    dependencies: []
    
  - id: agent-2
    role: Second specialist
    priority: 2
    dependencies: [agent-1]

workflow:
  mode: hybrid
  phases:
    - name: analysis
      type: parallel
      agents: [agent-1, agent-2]
      
    - name: synthesis
      type: sequential
      agents: [team-orchestrator]
      wait_for: analysis</code></pre>
      </div>
    </section>

    <!-- Best Practices -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-semibold text-[var(--color-text-primary)] mb-4">Best Practices</h2>
        <p class="text-lg text-[var(--color-text-secondary)]">Tips for building effective teams</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-2xl bg-gradient-to-br from-green-500/5 to-emerald-500/5 border border-green-500/20">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">Clear Responsibilities</h3>
              <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">Each agent should have ONE clear purpose. Avoid creating "do everything" agents.</p>
            </div>
          </div>
        </div>

        <div class="p-6 rounded-2xl bg-gradient-to-br from-blue-500/5 to-cyan-500/5 border border-blue-500/20">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">Proper Dependencies</h3>
              <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">Define clear dependency chains. Avoid circular dependencies between agents.</p>
            </div>
          </div>
        </div>

        <div class="p-6 rounded-2xl bg-gradient-to-br from-purple-500/5 to-pink-500/5 border border-purple-500/20">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">Shared Context</h3>
              <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">Use shared rules and templates for resources all agents need to access.</p>
            </div>
          </div>
        </div>

        <div class="p-6 rounded-2xl bg-gradient-to-br from-orange-500/5 to-red-500/5 border border-orange-500/20">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">Error Handling</h3>
              <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed">Configure retry logic and failure handling to make teams resilient.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section>
      <div class="relative overflow-hidden p-16 rounded-3xl bg-gradient-to-br from-blue-500/10 via-purple-500/10 to-pink-500/10 border border-blue-500/20 text-center">
        <div class="relative z-10 max-w-3xl mx-auto">
          <h2 class="text-4xl font-semibold text-[var(--color-text-primary)] mb-4">Ready to Build?</h2>
          <p class="text-xl text-[var(--color-text-secondary)] mb-8 leading-relaxed">
            Start with our template and create your first autonomous team in minutes
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a 
              href="/autonomous-teams/autonomous-team-template"
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-[var(--color-primary-500)] text-white font-medium hover:bg-[var(--color-primary-600)] transition-colors shadow-lg shadow-[var(--color-primary-500)]/20"
            >
              <span>Get the Template</span>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a 
              href="https://github.com/bitreonx/Autonomous-Agent-Teams"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-[var(--color-surface-2)] text-[var(--color-text-primary)] font-medium border border-[var(--color-border)] hover:border-[var(--color-primary-500)]/30 transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              <span>View on GitHub</span>
            </a>
          </div>
        </div>
      </div>
    </section>

  </div>

  <SearchModal client:idle />
  <CartSidebar client:idle />
</DashboardLayout>
