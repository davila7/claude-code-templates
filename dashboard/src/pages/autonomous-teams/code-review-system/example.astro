---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import TopBar from '../../../components/TopBar.astro';
import MarkdownViewer from '../../../components/MarkdownViewer.tsx';
import FileExplorer from '../../../components/FileExplorer.tsx';
import SearchModal from '../../../components/SearchModal.tsx';
import CartSidebar from '../../../components/CartSidebar.tsx';
import { readFile, readdir } from 'node:fs/promises';
import { resolve, join } from 'node:path';

export const prerender = true;

// Read the example review markdown file
let exampleContent = '';
let headings: { level: number; text: string; id: string }[] = [];

try {
  const filePath = resolve('../cli-tool/components/agents/development-tools/code-review-system/EXAMPLE_REVIEW.md');
  exampleContent = await readFile(filePath, 'utf-8');
  
  // Extract headings for TOC
  const headingRegex = /^(#{1,4})\s+(.+)$/gm;
  let m;
  while ((m = headingRegex.exec(exampleContent)) !== null) {
    const text = m[2].replace(/[*_`\[\]]/g, '').trim();
    const id = text.toLowerCase().replace(/[^\w]+/g, '-').replace(/^-|-$/g, '');
    headings.push({ level: m[1].length, text, id });
  }
} catch (e) {
  console.error('Failed to load example review:', e);
  exampleContent = '# Error\n\nFailed to load the example review.';
}

// Build file tree structure
const fileTree = [
  {
    name: 'code-review-system',
    path: 'code-review-system',
    type: 'folder' as const,
    children: [
      { name: 'EXAMPLE_REVIEW.md', path: 'EXAMPLE_REVIEW.md', type: 'file' as const },
      { name: 'INDEX.md', path: 'INDEX.md', type: 'file' as const },
      { name: 'README.md', path: 'README.md', type: 'file' as const },
      { name: 'CHANGELOG.md', path: 'CHANGELOG.md', type: 'file' as const },
      { name: 'orchestrator.md', path: 'orchestrator.md', type: 'file' as const },
      { name: 'review-planner.md', path: 'review-planner.md', type: 'file' as const },
      { name: 'team.yaml', path: 'team.yaml', type: 'file' as const },
      {
        name: 'reviewers',
        path: 'reviewers',
        type: 'folder' as const,
        children: [
          { name: 'security-reviewer.md', path: 'reviewers/security-reviewer.md', type: 'file' as const },
          { name: 'code-reviewer.md', path: 'reviewers/code-reviewer.md', type: 'file' as const },
          { name: 'architecture-reviewer.md', path: 'reviewers/architecture-reviewer.md', type: 'file' as const },
          { name: 'frontend-reviewer.md', path: 'reviewers/frontend-reviewer.md', type: 'file' as const },
          { name: 'backend-reviewer.md', path: 'reviewers/backend-reviewer.md', type: 'file' as const },
        ]
      },
      {
        name: 'rules',
        path: 'rules',
        type: 'folder' as const,
        children: [
          { name: 'security.md', path: 'rules/security.md', type: 'file' as const },
          { name: 'algorithms.md', path: 'rules/algorithms.md', type: 'file' as const },
          { name: 'concurrency.md', path: 'rules/concurrency.md', type: 'file' as const },
          { name: 'cross-file.md', path: 'rules/cross-file.md', type: 'file' as const },
          { name: 'predictive.md', path: 'rules/predictive.md', type: 'file' as const },
        ]
      },
    ]
  }
];

const title = 'Code Review Team — Real Example Review';
const description = 'Real-world example: We used the Code Review Team to analyze our Astro dashboard and found 32 actionable issues across security, performance, code quality, and accessibility.';
---

<DashboardLayout title={title} description={description}>
  <TopBar />
  
  <div class="max-w-7xl mx-auto">
    
    <!-- Back nav -->
    <div class="px-6 pt-8">
      <a
        href="/autonomous-teams/code-review-system"
        class="inline-flex items-center gap-2 text-[13px] font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors duration-200 group"
      >
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Code Review Team
      </a>
    </div>

    <!-- Header -->
    <div class="px-6 py-12">
      <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-[var(--color-surface-1)] to-[var(--color-surface-2)] border border-[var(--color-border)] p-12">
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-6">
            <span class="px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20 text-green-500 text-xs font-medium">Real Example</span>
            <span class="text-sm text-[var(--color-text-tertiary)]">•</span>
            <span class="text-sm text-[var(--color-text-secondary)]">March 27, 2026</span>
          </div>
          <h1 class="text-5xl font-semibold text-[var(--color-text-primary)] mb-4 tracking-tight">
            Dashboard Code Review Results
          </h1>
          <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed max-w-3xl">
            We used the Code Review Team to analyze our own Astro dashboard. The autonomous team of 17 specialized agents found 32 actionable issues across security, performance, code quality, and accessibility.
          </p>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="px-6 pb-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-6 rounded-2xl bg-[var(--color-surface-1)] border border-[var(--color-border)]">
          <div class="text-4xl font-semibold text-red-500 mb-2">4</div>
          <div class="text-sm text-[var(--color-text-secondary)]">Critical Issues</div>
        </div>
        <div class="p-6 rounded-2xl bg-[var(--color-surface-1)] border border-[var(--color-border)]">
          <div class="text-4xl font-semibold text-orange-500 mb-2">8</div>
          <div class="text-sm text-[var(--color-text-secondary)]">High Priority</div>
        </div>
        <div class="p-6 rounded-2xl bg-[var(--color-surface-1)] border border-[var(--color-border)]">
          <div class="text-4xl font-semibold text-yellow-500 mb-2">12</div>
          <div class="text-sm text-[var(--color-text-secondary)]">Medium Priority</div>
        </div>
        <div class="p-6 rounded-2xl bg-[var(--color-surface-1)] border border-[var(--color-border)]">
          <div class="text-4xl font-semibold text-blue-500 mb-2">8</div>
          <div class="text-sm text-[var(--color-text-secondary)]">Low Priority</div>
        </div>
      </div>
    </div>

    <!-- Main Content with File Explorer -->
    <div class="px-6 pb-16 grid lg:grid-cols-4 gap-8">
      
      <!-- File Explorer Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-8">
          <h2 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4 px-3">Project Files</h2>
          <div class="rounded-2xl bg-[var(--color-surface-1)] border border-[var(--color-border)] p-3 max-h-[calc(100vh-200px)] overflow-y-auto">
            <FileExplorer 
              client:load
              files={fileTree}
              onFileSelect={(path) => console.log('Selected:', path)}
              selectedFile="EXAMPLE_REVIEW.md"
            />
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="lg:col-span-3">
        <MarkdownViewer
          client:load
          content={exampleContent}
          headings={headings}
        />
      </div>
      
    </div>

  </div>

  <SearchModal client:idle />
  <CartSidebar client:idle />
</DashboardLayout>
